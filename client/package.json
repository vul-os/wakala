{
  "name": "@vulos/relay-client",
  "private": false,
  "version": "0.2.0",
  "description": "JS client SDK for the Vulos peer-fabric — endpoint failover, offline bootstrap, WebRTC signaling, presence, live cursors. Talks to the host application's peering backend over HTTP/WebSocket.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build --config vite.config.lib.js && npm run build:types",
    "build:lib": "vite build --config vite.config.lib.js",
    "build:types": "tsc -p tsconfig.dts.json",
    "test": "vitest run"
  },
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.js",
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js",
      "require": "./dist-lib/index.cjs",
      "default": "./dist-lib/index.js"
    },
    "./errors": {
      "source": "./src/errors.js",
      "types": "./dist-lib/errors.d.ts",
      "import": "./dist-lib/errors.js",
      "require": "./dist-lib/errors.cjs",
      "default": "./dist-lib/errors.js"
    },
    "./endpoints": {
      "source": "./src/endpoints.js",
      "types": "./dist-lib/endpoints.d.ts",
      "import": "./dist-lib/endpoints.js",
      "require": "./dist-lib/endpoints.cjs",
      "default": "./dist-lib/endpoints.js"
    },
    "./offlineBootstrap": {
      "source": "./src/offlineBootstrap.js",
      "types": "./dist-lib/offlineBootstrap.d.ts",
      "import": "./dist-lib/offlineBootstrap.js",
      "require": "./dist-lib/offlineBootstrap.cjs",
      "default": "./dist-lib/offlineBootstrap.js"
    },
    "./signaling": {
      "source": "./src/signaling.js",
      "types": "./dist-lib/signaling.d.ts",
      "import": "./dist-lib/signaling.js",
      "require": "./dist-lib/signaling.cjs",
      "default": "./dist-lib/signaling.js"
    },
    "./fabric": {
      "source": "./src/fabric.js",
      "types": "./dist-lib/fabric.d.ts",
      "import": "./dist-lib/fabric.js",
      "require": "./dist-lib/fabric.cjs",
      "default": "./dist-lib/fabric.js"
    },
    "./presence": {
      "source": "./src/presence.js",
      "types": "./dist-lib/presence.d.ts",
      "import": "./dist-lib/presence.js",
      "require": "./dist-lib/presence.cjs",
      "default": "./dist-lib/presence.js"
    },
    "./call": {
      "source": "./src/call/index.js",
      "types": "./dist-lib/call/index.d.ts",
      "import": "./dist-lib/call.js",
      "require": "./dist-lib/call.cjs",
      "default": "./dist-lib/call.js"
    },
    "./useLiveCursors": {
      "source": "./src/useLiveCursors.js",
      "types": "./dist-lib/useLiveCursors.d.ts",
      "import": "./dist-lib/useLiveCursors.js",
      "require": "./dist-lib/useLiveCursors.cjs",
      "default": "./dist-lib/useLiveCursors.js"
    },
    "./health": {
      "source": "./src/health.js",
      "types": "./dist-lib/health.d.ts",
      "import": "./dist-lib/health.js",
      "require": "./dist-lib/health.cjs",
      "default": "./dist-lib/health.js"
    },
    "./roundTripCheck": {
      "source": "./src/roundTripCheck.js",
      "types": "./dist-lib/roundTripCheck.d.ts",
      "import": "./dist-lib/roundTripCheck.js",
      "require": "./dist-lib/roundTripCheck.cjs",
      "default": "./dist-lib/roundTripCheck.js"
    },
    "./regionPop": {
      "source": "./src/regionPop.js",
      "types": "./dist-lib/regionPop.d.ts",
      "import": "./dist-lib/regionPop.js",
      "require": "./dist-lib/regionPop.cjs",
      "default": "./dist-lib/regionPop.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist-lib/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "xlsx": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0"
  }
}
