# Demo/reference defaults for this repo's build — no secrets. See console/README.md.
#
# VITE_MOCK=1 (default): the console runs entirely on the fixtures in src/lib/api.ts, no
# backend required. Set VITE_MOCK=0 to talk to a real `wakala-admin` at VITE_API_BASE.
VITE_MOCK=1
VITE_API_BASE=http://127.0.0.1:8090
